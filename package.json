{
  "name": "thermal-stat-skeleton",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "generate:data": "node scripts/generate-thermal-corpus.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "build": "tsc -b && vite build",
    "package:release": "npm run generate:data && npm run validate:data && npm run build && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-release.ps1",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "d3-force": "^3.0.0",
    "katex": "^0.16.25",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
