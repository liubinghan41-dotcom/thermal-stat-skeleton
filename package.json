{
  "name": "thermal-stat-skeleton",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@10.8.3",
  "engines": {
    "node": ">=20.10.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "check:env": "node scripts/check-env.mjs",
    "setup": "npm run check:env && npm ci && npm run lint:data",
    "start:local": "npm run check:env && npm run dev",
    "lint:data": "npm run generate:data && npm run validate:data",
    "check": "npm run lint:data && npm run build",
    "generate:data": "node scripts/generate-thermal-corpus.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "build": "tsc -b && vite build",
    "icons": "node scripts/generate-icons.mjs",
    "package:release": "npm run lint:data && npm run build && node scripts/package-release.mjs",
    "test:smoke": "node -e \"console.log('smoke: setup done and validation/build commands are available');\"",
    "preview": "vite preview --host 127.0.0.1",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:apk": "node scripts/cap-apk.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "d3-force": "^3.0.0",
    "katex": "^0.16.25",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.3.0"
  }
}
